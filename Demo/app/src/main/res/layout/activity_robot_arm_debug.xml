<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2D3436"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Connection Settings Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="连接配置 (Connection)"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/inputHost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:hint="Host (e.g. 10.0.2.2)"
                android:inputType="textUri" />

            <EditText
                android:id="@+id/inputPort"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Port"
                android:inputType="number" />
        </LinearLayout>

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_connect"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnDisconnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_disconnect"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- Control Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关节控制 (Joint Control)"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/inputMoveJ"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Joint values (comma-separated)"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnMoveJ"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_movej"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/inputGripper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Gripper values"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnGripper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_gripper"
            android:layout_marginBottom="24dp" />

        <!-- Status & Monitoring -->
        <Button
            android:id="@+id/btnSubscribeJointStates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_subscribe"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="#EDF2F7"
            android:textColor="#4A5568"
            android:textSize="14sp"
            android:text="Waiting for operation..." />

    </LinearLayout>
</ScrollView>
